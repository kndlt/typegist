{
  "name": "@kndlt/typegist",
  "version": "0.1.3",
  "description": "Generate a bird's-eye-view .d.ts of your TypeScript project",
  "type": "module",
  "bin": {
    "typegist": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "types",
    "ai",
    "agents",
    "dts",
    "declaration"
  ],
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
